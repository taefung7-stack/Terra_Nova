{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terranova.app/schemas/passage-2.2.json",
  "title": "Terra Nova Passage v2.2",
  "type": "object",
  "required": ["schema_version", "id", "meta", "page1", "page2", "page3", "page4", "answers"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "enum": ["2.1", "2.2"] },
    "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}(-[A-Z])?-\\d{2}$" },
    "meta": {
      "type": "object",
      "required": ["month", "sequence", "subject", "linked_unit", "part_ko", "achievement_standard", "difficulty", "cognitive_skill", "lexile", "ar_level", "key_concepts"],
      "additionalProperties": false,
      "properties": {
        "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}(-[A-Z])?$" },
        "sequence": { "type": "integer", "minimum": 1, "maximum": 20 },
        "subject": { "enum": ["통합과학", "통합사회", "공통수학", "공통국어", "공통영어", "한국사", "정보", "수학", "국어", "영어", "예체능·정보", "과학", "사회"] },
        "linked_unit": { "type": "string", "minLength": 3, "maxLength": 120 },
        "part_ko": { "type": "string", "minLength": 2, "maxLength": 24 },
        "achievement_standard": { "type": "string", "pattern": "^(10(통과|통사|공국|공수|공영|한사)[12]-\\d{2}-\\d{2}|(9|10|12)[가-힣A-Z]{1,5}\\d{2}-\\d{2})$" },
        "achievement_verified": { "type": "boolean", "description": "2022 개정 NCIC 평가기준 기준 코드 정확성 검수 여부. true=공식 자료로 1:1 검증 완료, false=본문 기반 추정값(검수 대기)." },
        "difficulty": { "enum": ["쉬움", "중간", "어려움", "도전"] },
        "cognitive_skill": { "type": "string", "minLength": 2, "maxLength": 30 },
        "lexile": { "type": "string", "pattern": "^\\d{3,4}L$" },
        "ar_level": { "type": "number", "minimum": 3.0, "maximum": 12.0 },
        "key_concepts": { "type": "array", "minItems": 2, "maxItems": 5, "items": { "type": "string", "minLength": 1, "maxLength": 30 } }
      }
    },
    "page1": {
      "type": "object",
      "required": ["title", "subtitle", "body", "illustration", "illustration_caption"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 3, "maxLength": 80 },
        "subtitle": { "type": "string", "minLength": 3, "maxLength": 110 },
        "body": { "type": "string", "minLength": 1400, "maxLength": 3200 },
        "illustration": { "type": "string", "pattern": "^\\.\\./\\.\\./assets/illustrations/\\d{4}-\\d{2}(-[A-Z])?/\\d{2}\\.(svg|png|jpg|webp)$" },
        "illustration_caption": { "type": "string", "minLength": 3, "maxLength": 100 },
        "illustration_max_height_mm": { "type": "number", "minimum": 10, "maximum": 100, "description": "본문이 길어 이미지가 페이지 하단을 침범할 때, 시각적으로 보일 최대 높이(mm). 파일은 그대로 두고 CSS overflow:hidden으로 아래쪽만 잘라 표시." }
      }
    },
    "page2": {
      "type": "object",
      "required": ["questions", "textbook_tieback"],
      "additionalProperties": false,
      "properties": {
        "questions": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "oneOf": [
              {
                "type": "object",
                "required": ["type", "style", "stem", "choices", "answer_index"],
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "mock_objective" },
                  "style": { "type": "string", "minLength": 2, "maxLength": 30 },
                  "stem": { "type": "string", "minLength": 5, "maxLength": 400 },
                  "choices": { "type": "array", "minItems": 5, "maxItems": 5, "items": { "type": "string", "minLength": 1, "maxLength": 220 } },
                  "answer_index": { "type": "integer", "minimum": 0, "maximum": 4 }
                }
              },
              {
                "type": "object",
                "required": ["type", "style", "prompt", "model_answer"],
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "school_descriptive" },
                  "style": { "enum": ["요약문 빈칸 완성", "주제문 작성(조건제시)", "단어 순서 배열", "빈칸 어휘", "한줄 요약"] },
                  "prompt": { "type": "string", "minLength": 5, "maxLength": 500 },
                  "hints": { "type": "array", "minItems": 0, "maxItems": 12, "items": { "type": "string", "minLength": 1, "maxLength": 50 } },
                  "summary_template": { "type": "string", "minLength": 0, "maxLength": 500 },
                  "model_answer": { "type": "string", "minLength": 5, "maxLength": 500 }
                }
              }
            ]
          }
        },
        "textbook_tieback": {
          "type": "object",
          "required": ["unit_label", "body_ko", "tags"],
          "additionalProperties": false,
          "properties": {
            "unit_label": { "type": "string", "minLength": 3, "maxLength": 80 },
            "body_ko": { "type": "string", "minLength": 200, "maxLength": 600 },
            "tags": { "type": "array", "minItems": 2, "maxItems": 5, "items": { "type": "string", "minLength": 1, "maxLength": 24 } },
            "visual_aid": {
              "type": "object",
              "required": ["type", "title", "steps"],
              "additionalProperties": false,
              "properties": {
                "type": { "enum": ["emoji_flow", "compare", "mindmap", "timeline"] },
                "title": { "type": "string", "minLength": 1, "maxLength": 40 },
                "steps": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 6,
                  "items": {
                    "type": "object",
                    "required": ["emoji", "label"],
                    "additionalProperties": false,
                    "properties": {
                      "emoji": { "type": "string", "minLength": 1, "maxLength": 8 },
                      "label": { "type": "string", "minLength": 0, "maxLength": 30 },
                      "note": { "type": "string", "minLength": 0, "maxLength": 60 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "page3": {
      "type": "object",
      "required": ["sentences", "translation_ko"],
      "additionalProperties": false,
      "properties": {
        "sentences": {
          "type": "array",
          "minItems": 4,
          "maxItems": 20,
          "items": {
            "type": "object",
            "required": ["index", "segments"],
            "additionalProperties": false,
            "properties": {
              "index": { "type": "integer", "minimum": 1 },
              "segments": {
                "type": "array",
                "minItems": 1,
                "maxItems": 16,
                "items": {
                  "type": "object",
                  "required": ["role", "text"],
                  "additionalProperties": false,
                  "properties": {
                    "role": { "enum": ["S", "V", "O", "C", "M", "CONJ", "REL", ""] },
                    "text": { "type": "string", "minLength": 1, "maxLength": 180 },
                    "note": { "type": "string", "minLength": 1, "maxLength": 50 }
                  }
                }
              },
              "grammar_note": { "type": "string", "minLength": 1, "maxLength": 160 }
            }
          }
        },
        "translation_ko": { "type": "string", "minLength": 200, "maxLength": 2400 }
      }
    },
    "page4": {
      "type": "object",
      "required": ["vocab"],
      "additionalProperties": false,
      "properties": {
        "vocab": {
          "type": "array",
          "minItems": 10,
          "maxItems": 14,
          "items": {
            "type": "object",
            "required": ["word", "pos", "meaning_ko", "synonyms", "antonyms", "examples"],
            "additionalProperties": false,
            "properties": {
              "word": { "type": "string", "minLength": 1, "maxLength": 40 },
              "pos": { "type": "string", "minLength": 1, "maxLength": 10 },
              "meaning_ko": { "type": "string", "minLength": 1, "maxLength": 80 },
              "synonyms": { "type": "array", "minItems": 0, "maxItems": 4, "items": { "type": "string", "maxLength": 30 } },
              "antonyms": { "type": "array", "minItems": 0, "maxItems": 4, "items": { "type": "string", "maxLength": 30 } },
              "examples": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "object",
                  "required": ["en", "ko"],
                  "additionalProperties": false,
                  "properties": {
                    "en": { "type": "string", "minLength": 5, "maxLength": 200 },
                    "ko": { "type": "string", "minLength": 3, "maxLength": 140 }
                  }
                }
              },
              "exam_source": { "type": "string", "minLength": 3, "maxLength": 80 }
            }
          }
        }
      }
    },
    "answers": {
      "type": "object",
      "required": ["explanations"],
      "additionalProperties": false,
      "description": "정답·해설 보충자료. supplements.html answers 렌더러가 사용. q_index 0..3 = page2.questions[i] 와 1:1 매핑. 객관식: correct = answer_index, rationales 5개. 서술형(school_descriptive): correct = null, model_answer_en + rationales 2개((A)·(B)).",
      "properties": {
        "explanations": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["q_index", "q_style", "correct", "evidence", "rationales"],
            "additionalProperties": false,
            "properties": {
              "q_index": { "type": "integer", "minimum": 0, "maximum": 3 },
              "q_style": { "type": "string", "minLength": 2, "maxLength": 30 },
              "correct": {
                "oneOf": [
                  { "type": "integer", "minimum": 0, "maximum": 4 },
                  { "type": "null" }
                ],
                "description": "객관식: 0~4 (= page2.questions[q_index].answer_index 와 일치 필수). 서술형: null."
              },
              "evidence": { "type": "string", "minLength": 10, "maxLength": 600, "description": "정답 근거 1~2문장. 본문 인용 권장." },
              "rationales": {
                "type": "array",
                "minItems": 2,
                "maxItems": 5,
                "items": { "type": "string", "minLength": 5, "maxLength": 280 },
                "description": "객관식: 5개 (각 선지 분석, 정답 선지에 '(정답)' 접두어 권장). 서술형: 2개 ((A)·(B) 빈칸 풀이)."
              },
              "model_answer_en": { "type": "string", "minLength": 1, "maxLength": 200, "description": "서술형 전용. 예: '(A) bonds  (B) shapes'" },
              "key_terms": {
                "type": "array",
                "maxItems": 6,
                "items": {
                  "type": "object",
                  "required": ["en", "ko"],
                  "additionalProperties": false,
                  "properties": {
                    "en": { "type": "string", "minLength": 1, "maxLength": 60 },
                    "ko": { "type": "string", "minLength": 1, "maxLength": 60 }
                  }
                },
                "description": "선택 항목. 현재 렌더링되지 않음 (보존 목적)."
              }
            }
          }
        }
      }
    }
  }
}
